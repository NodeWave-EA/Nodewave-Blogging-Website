# .env.example for NodeWave Blogging Website Frontend

# Base API URL for Strapi backend
VITE_API_URL=http://localhost:1337/api

# Site URL (used for SEO, RSS, etc.)
VITE_SITE_URL=http://localhost:5173

# Feature toggles (optional, add as needed)
# VITE_FEATURE_X=true

# Theme (optional, can be set by user in localStorage)
# VITE_DEFAULT_THEME=system

# Analytics (optional)
# VITE_GOOGLE_ANALYTICS_ID=

# Any other environment variables used by your project can be added here
