# Server Configuration
HOST=0.0.0.0
PORT=1337
NODE_ENV=development

STRAPI_API_URL=http://localhost:1337
STRAPI_ADMIN_URL=http://localhost:1337/admin


# Security Keys (Generate new ones for production)
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Authentication Configuration
ADMIN_REGISTRATION_ENABLED=true
ALLOW_REGISTER=true
EMAIL_CONFIRMATION=false
UNIQUE_EMAIL=true

# =================================
# EMAIL CONFIGURATION
# =================================

# Email Provider: 'smtp' or 'gmail-api'
EMAIL_PROVIDER=smtp

# Default email settings
EMAIL_DEFAULT_FROM=noreply@nodewave.blog
EMAIL_DEFAULT_REPLY_TO=support@nodewave.blog
EMAIL_TEST_ADDRESS=test@example.com
ADMIN_EMAIL=admin@nodewave.blog

# Company branding (used in email templates)
COMPANY_NAME=NodeWave Blog

# =================================
# SMTP Configuration (when EMAIL_PROVIDER=smtp)
# =================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_REQUIRE_TLS=true
SMTP_CONNECTION_TIMEOUT=60000
SMTP_GREETING_TIMEOUT=30000
SMTP_SOCKET_TIMEOUT=60000

# Alternative SMTP providers:
# For Outlook/Hotmail: smtp-mail.outlook.com, port 587
# For Yahoo: smtp.mail.yahoo.com, port 587
# For custom domains: check your hosting provider's SMTP settings

# =================================
# Gmail API OAuth2 Configuration (when EMAIL_PROVIDER=gmail-api)
# =================================

GMAIL_USER=your-email@gmail.com
GMAIL_CLIENT_ID=your-google-client-id.googleusercontent.com
GMAIL_CLIENT_SECRET=your-google-client-secret
GMAIL_REFRESH_TOKEN=your-google-refresh-token
GMAIL_ACCESS_TOKEN=your-google-access-token

# Note: To set up Gmail API OAuth2:
# 1. Create project in Google Cloud Console
# 2. Enable Gmail API
# 3. Create OAuth2 credentials
# 4. Use OAuth2 playground to get refresh token
# 5. Set up OAuth2 consent screen

# Database Configuration
DATABASE_CLIENT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=nodewave_blog
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password
DATABASE_SSL=false

# Blog Configuration
SEED_DATABASE=false
BLOG_URL=http://localhost:1337
FRONTEND_URL=http://localhost:3000

# Email Configuration (SMTP only)
EMAIL_PROVIDER=smtp

# Default email settings
EMAIL_DEFAULT_FROM=noreply@nodewave.blog
EMAIL_DEFAULT_REPLY_TO=support@nodewave.blog
EMAIL_TEST_ADDRESS=test@example.com
ADMIN_EMAIL=admin@nodewave.blog

# Company branding (used in email templates)
COMPANY_NAME=NodeWave Blog

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_REJECT_UNAUTHORIZED=true

# Alternative SMTP providers:
# For Outlook/Hotmail: smtp-mail.outlook.com, port 587
# For Yahoo: smtp.mail.yahoo.com, port 587
# For custom domains: check your hosting provider's SMTP settings

# SendGrid Configuration (alternative to SMTP)
SENDGRID_API_KEY=your-sendgrid-api-key

# CDN/Storage Configuration (optional)
CLOUDINARY_NAME=your-cloudinary-name
CLOUDINARY_KEY=your-cloudinary-key
CLOUDINARY_SECRET=your-cloudinary-secret

# Analytics & Monitoring
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
SENTRY_DSN=your-sentry-dsn

# Social Media Integration
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000

# Cache Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Feature Flags
ENABLE_COMMENTS=true
ENABLE_NEWSLETTER=true
ENABLE_SEARCH=true
ENABLE_ANALYTICS=true
