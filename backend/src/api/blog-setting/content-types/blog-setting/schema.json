{
  "kind": "collectionType",
  "collectionName": "blog_settings",
  "info": {
    "singularName": "blog-setting",
    "pluralName": "blog-settings",
    "displayName": "Blog Settings",
    "description": "Global blog configuration and settings"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "site_name": {
      "type": "string",
      "required": true,
      "maxLength": 100,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "site_description": {
      "type": "text",
      "maxLength": 500,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "site_url": {
      "type": "string",
      "required": true
    },
    "site_logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "site_favicon": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "default_author": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::author.author"
    },
    "posts_per_page": {
      "type": "integer",
      "default": 10,
      "min": 1,
      "max": 50
    },
    "allow_comments": {
      "type": "boolean",
      "default": true
    },
    "moderate_comments": {
      "type": "boolean",
      "default": true
    },
    "social_links": {
      "type": "component",
      "repeatable": true,
      "component": "shared.social-link"
    },
    "analytics_code": {
      "type": "text"
    },
    "tracking_scripts": {
      "type": "text"
    },
    "custom_css": {
      "type": "text"
    },
    "custom_js": {
      "type": "text"
    },
    "footer_text": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "contact_email": {
      "type": "email"
    },
    "maintenance_mode": {
      "type": "boolean",
      "default": false
    },
    "maintenance_message": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "newsletter_enabled": {
      "type": "boolean",
      "default": true
    },
    "rss_enabled": {
      "type": "boolean",
      "default": true
    },
    "sitemap_enabled": {
      "type": "boolean",
      "default": true
    },
    "search_enabled": {
      "type": "boolean",
      "default": true
    },
    "theme": {
      "type": "enumeration",
      "enum": ["light", "dark", "auto"],
      "default": "light"
    },
    "timezone": {
      "type": "string",
      "default": "UTC"
    },
    "date_format": {
      "type": "string",
      "default": "YYYY-MM-DD"
    },
    "time_format": {
      "type": "string",
      "default": "HH:mm"
    }
  }
}
