{
  "kind": "collectionType",
  "collectionName": "company_infos",
  "info": {
    "singularName": "company-info",
    "pluralName": "company-infos",
    "displayName": "Company Information",
    "description": "General company information and settings for the blog"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "site_title": {
      "type": "string",
      "required": true,
      "default": "NodeWave Blog"
    },
    "site_description": {
      "type": "text",
      "required": true
    },
    "company_name": {
      "type": "string",
      "required": true,
      "default": "NodeWave"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "logo_dark": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "favicon": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "contact_email": {
      "type": "email",
      "required": true
    },
    "contact_phone": {
      "type": "string"
    },
    "address": {
      "type": "text"
    },
    "website_url": {
      "type": "string",
      "required": true
    },
    "social_links": {
      "type": "component",
      "repeatable": true,
      "component": "shared.social-link"
    },
    "about_company": {
      "type": "richtext"
    },
    "mission_statement": {
      "type": "richtext"
    },
    "vision_statement": {
      "type": "richtext"
    },
    "founded_year": {
      "type": "integer",
      "min": 1900,
      "max": 2100
    },
    "team_size": {
      "type": "integer",
      "min": 1
    },
    "newsletter_enabled": {
      "type": "boolean",
      "default": true
    },
    "comments_enabled": {
      "type": "boolean",
      "default": true
    },
    "google_analytics_id": {
      "type": "string"
    },
    "meta_keywords": {
      "type": "text"
    },
    "og_image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
